# ── Database (Supabase / PostgreSQL) ────────────────────────────────
POSTGRES_DB=fyp_database
POSTGRES_USER=fyp_user
POSTGRES_PASSWORD=fyp_user
# Use your Supabase pooled connection string for production:
# DATABASE_URL=postgresql://postgres.<project>:<pass>@aws-1-ap-southeast-1.pooler.supabase.com:5432/postgres
DATABASE_URL=postgresql://fyp_user:fyp_user@localhost:5432/fyp_database

# ── AI pipeline (all optional — defaults shown) ─────────────────────
# Hardware
AI_CTX_ID=-1              # -1 CPU, 0 first GPU
AI_DEVICE=cpu             # cpu | cuda

# Detection
AI_DET_THRESH=0.5
AI_USE_MTCNN=true

# Recognition thresholds (cosine similarity)
AI_ARCFACE_THRESHOLD=0.40
AI_FACENET_THRESHOLD=0.55
AI_USE_FACENET=true

# Ensemble voting weights (summed, relative)
AI_ARCFACE_WEIGHT=0.65
AI_FACENET_WEIGHT=0.35
AI_ENSEMBLE_IOU=0.4

# Image enhancement (GAN)
AI_USE_ENHANCER=true
AI_ENHANCER=auto          # auto | clahe | gfpgan | realesrgan
AI_ENHANCE_LOW_LIGHT_ONLY=true
AI_LOW_LIGHT_MEAN=80

# PDPC
AI_EMBEDDING_RETENTION_DAYS=365
